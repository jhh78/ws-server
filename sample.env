# 샘플 설정 — 게임·채팅 공통 실시간 서버
# 사용: cp sample.env .env
#
# 활성 설정은 프로젝트 루트 .env 한 개입니다.

SERVER_NAME=ws-server

# TCP
NETWORK=tcp
LISTEN_ADDR=:8080

# WebSocket (HTTP upgrade over TCP)
WS_PATH=/ws
HEALTH_PATH=/health
READ_BUFFER_SIZE=4096
WRITE_BUFFER_SIZE=4096
ALLOW_ORIGINS=*

# Area (맵/존/로비) — 0 = 무제한
MAX_CLIENTS_PER_AREA=500
MAX_AREAS=10000

# Channel (파티/길드/귓속말 방/커스텀) — 0 = 무제한
MAX_CHANNELS=20000
MAX_CLIENTS_PER_CHANNEL=200

# =============================================================================
# 로그 — 시스템 / 액세스 각각 등록
# MODE: off | file | db
#   off  — 기록 안 함
#   file — 아래 *_LOG_FILE 경로
#   db   — LOG_DB_DRIVER + LOG_DB_DSN (sqlite | mysql | postgres)
# 시스템·액세스는 모드를 서로 다르게 둘 수 있음 (예: 시스템 file, 액세스 db)
# =============================================================================

# --- 시스템 로그 ---
# 기동, 접속/종료, 업그레이드 실패, listen 오류 등 (INFO / WARN / ERROR)
SYSTEM_LOG_MODE=file
SYSTEM_LOG_FILE=logs/system.log

# --- 액세스 로그 ---
# connect / disconnect / join / leave / send / whisper / ping / error / upgrade_fail
ACCESS_LOG_MODE=file
ACCESS_LOG_FILE=logs/access.log

# --- DB 로그 (SYSTEM_LOG_MODE 또는 ACCESS_LOG_MODE 가 db 일 때 공통) ---
# LOG_DB_DRIVER: sqlite | mysql | postgres
#   별칭: sqlite3, mariadb, postgresql, pg
# 기동 시 테이블 system_logs, access_logs 자동 생성
#
# LOG_DB_DSN 예:
#   sqlite:    logs/ws-server.db
#   mysql:     user:password@tcp(127.0.0.1:3306)/ws_logs?parseTime=true&charset=utf8mb4
#   postgres:  postgres://user:password@127.0.0.1:5432/ws_logs?sslmode=disable

LOG_DB_DRIVER=sqlite
LOG_DB_DSN=logs/ws-server.db

# MySQL 예시:
# LOG_DB_DRIVER=mysql
# LOG_DB_DSN=ws:secret@tcp(127.0.0.1:3306)/ws_logs?parseTime=true&charset=utf8mb4

# PostgreSQL 예시:
# LOG_DB_DRIVER=postgres
# LOG_DB_DSN=postgres://ws:secret@127.0.0.1:5432/ws_logs?sslmode=disable

# =============================================================================
# 웹훅 (선택) — 중계 이벤트 알림
# 비어 있으면 비활성. 설정 시 connect/disconnect/join/leave/send/whisper/ping 을
# JSON POST 로 전송 (비동기, 실패해도 중계는 계속).
#
# WEBHOOK_URL 은 JSON 배열 문자열만 허용:
#   WEBHOOK_URL=["https://a.example/hook","https://b.example/hook"]
#   WEBHOOK_URL=["https://one.example/hook"]
# =============================================================================
WEBHOOK_URL=
# WEBHOOK_URL=["https://a.example/hook","https://b.example/hook"]
WEBHOOK_TIMEOUT_MS=5000
